function fibonacciGenerator (number) {
    var output = [];
    var nextNumber;
    if (number === 1) {
        output = [0];
        return output;
        }
        else if (number === 2) {
            output = [0, 1];
            return output;
        }
    else {
        output = [0, 1];
        while (output.length < number) {
        nextNumber = output[output.length - 1] + output[output.length - 2];
        output.push(nextNumber);
        }
    }
    return output;
}

