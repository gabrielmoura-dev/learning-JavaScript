function bmiCalculator(weight, height) {
  var bmi = Math.round(weight / Math.pow(height, 2));
  var mensagemFinal;

  if (bmi < 18.5) {
    mensagemFinal = "Your BMI is " + bmi + ", so you are underweight.";
  }

  if (bmi >= 18.5 && bmi <= 24.9) {
    mensagemFinal = "Your BMI is " + bmi + ", so you have a normal weight.";
  }

  if (bmi > 24.9) {
    mensagemFinal = "Your BMI is " + bmi + ", so you are overweight.";
  }

  return mensagemFinal;
}
