// Constructor Object
function agenteDeBagagens (nome, idade, permissaoDeTrabalho, linguasFaladas) {
    this.nome = nome;
    this.idade = idade;
    this.permissaoDeTrabalho = permissaoDeTrabalho;
    this.linguasFaladas = linguasFaladas;
}

// exemplo final de como ficaria - roda essa função antes de criar a variável
function empregadaDomestica (nome, idade, anosDeExperiencia, linguasFaladas) {
    this.nome = nome;
    this.idade = idade;
    this.anosDeExperiencia = anosDeExperiencia;
    this.linguasFaladas = linguasFaladas;
}

